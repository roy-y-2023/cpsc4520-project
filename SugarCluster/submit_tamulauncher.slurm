#!/bin/bash
# TAMULauncher-based submission for the Sugarscape parameter sweep.
#
# Replaces the SLURM job-array approach (submit.slurm) when the array size
# would exceed ACES QOS limits.  TAMULauncher handles concurrency across
# all allocated cores with automatic restart/checkpointing.
#
# Prerequisites:
#   1. Generate configs:   python generate_configs.py
#   2. Generate commands:  python generate_commands.py \
#                              --project-dir /scratch/.../cpsc4520-project
#   3. Submit this script (run from inside SugarCluster/):
#                          PROJECT_DIR=/scratch/.../cpsc4520-project \
#                              sbatch -A <account> submit_tamulauncher.slurm
#
# TAMULauncher notes:
#   - No module load required; tamulauncher is available on all ACES nodes.
#   - Do NOT use with MPI commands.
#   - Restart is automatic: resubmit with the same commands.txt and
#     already-finished sims are skipped.
#   - Use `tamulauncher --status commands.txt` to check progress.
#   - Use `tamulauncher --norestart commands.txt` to force a fresh start.

#SBATCH --job-name=sugarscape-tamulauncher
#SBATCH --nodes=8
#SBATCH --ntasks-per-node=16
#SBATCH --time=01:00:00
#SBATCH --mem=8G         # 48 sims × ~36 MB max peak = ~1.7 GB; 8G gives 4× headroom
#SBATCH --output=logs/tamulauncher-%j.out
#SBATCH --error=logs/tamulauncher-%j.err

set -euo pipefail

# --- Configuration ---
# PROJECT_DIR: root containing SugarCluster/ and sugarscape/
# COMMANDS_PER_NODE: concurrent sims per node (≤ ntasks-per-node)
# COMMANDS_FILE: path to the commands file generated by generate_commands.py
# ---------------------

PROJECT_DIR="${PROJECT_DIR:-}"
COMMANDS_PER_NODE="${COMMANDS_PER_NODE:-16}"

# Strip /SugarCluster from PROJECT_DIR if accidentally included
if [ -n "$PROJECT_DIR" ] && [[ "$PROJECT_DIR" == */SugarCluster* ]]; then
    PROJECT_DIR="${PROJECT_DIR%/SugarCluster*}"
fi

# Auto-detect relative to this script if PROJECT_DIR not set
if [ -z "$PROJECT_DIR" ]; then
    PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.."
fi

COMMANDS_FILE="${COMMANDS_FILE:-${PROJECT_DIR}/SugarCluster/commands.txt}"

# Ensure Python 3.12+ is available
if command -v module &> /dev/null; then
    module load GCCcore/13.3.0 Python/3.12.3
fi

# Activate venv so python3 on PATH resolves to the venv's interpreter.
# TAMULauncher worker shells inherit environment variables (PATH, VIRTUAL_ENV)
# from this script, so each command line in commands.txt gets the right python3.
if [ -f "${PROJECT_DIR}/SugarCluster/.venv/bin/activate" ]; then
    source "${PROJECT_DIR}/SugarCluster/.venv/bin/activate"
    echo "  Venv activated  : ${PROJECT_DIR}/SugarCluster/.venv"
else
    echo "  WARNING: .venv not found — using module-loaded python3"
    echo "  Run setup_aces.sh first if dependencies are missing."
fi

# Sanity checks
if [ ! -f "$COMMANDS_FILE" ]; then
    echo "ERROR: commands.txt not found at: $COMMANDS_FILE"
    echo "Run: python SugarCluster/generate_commands.py --project-dir $PROJECT_DIR"
    exit 1
fi

TOTAL_CMDS=$(wc -l < "$COMMANDS_FILE")
echo "=== TAMULauncher Submission ==="
echo "  Project dir   : $PROJECT_DIR"
echo "  Commands file : $COMMANDS_FILE ($TOTAL_CMDS commands)"
echo "  Nodes         : $SLURM_JOB_NUM_NODES"
echo "  Per-node      : $COMMANDS_PER_NODE concurrent"
echo "  Max parallel  : $(( SLURM_JOB_NUM_NODES * COMMANDS_PER_NODE ))"
echo "================================"

mkdir -p "${PROJECT_DIR}/SugarCluster/logs"

# cd into SugarCluster/ so all sim output JSONs (written to cwd by sugarscape)
# land there predictably, regardless of where sbatch was called from.
cd "${PROJECT_DIR}/SugarCluster"

# Run all commands concurrently via TAMULauncher
tamulauncher --norestart --commands-pernode "${COMMANDS_PER_NODE}" "${COMMANDS_FILE}"

echo "=== TAMULauncher job complete ==="
echo "Check per-sim timing JSON files in: ${PROJECT_DIR}/SugarCluster/"
echo "To check status:  tamulauncher --status ${COMMANDS_FILE}"
